# --- Core auth/config ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=n8n
DIFY_DB_NAME=dify
N8N_DB_NAME=n8n
FLOWISE_DB_NAME=flowise
GITEA_DB_NAME=gitea
RAGFLOW_DB_NAME=ragflow
MYSQL_ROOT_PASSWORD=password

# --- LLM and vector services ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_BOOTSTRAP_MODEL=qwen3.5-8B
QDRANT_URL=http://qdrant:6333

# --- Access tokens/credentials ---
JUPYTER_TOKEN=password
MERCURE_PUBLISHER_JWT_KEY=change-me-secret
MERCURE_SUBSCRIBER_JWT_KEY=change-me-secret
COUCHDB_USER=admin
COUCHDB_PASSWORD=password

# --- Internal service URLs ---
DIFY_API_URL=http://dify-api:5001
N8N_BASE_URL=http://n8n:5678
GITEA_URL=http://gitea:3000
SEARXNG_URL=http://searxng:8080
MERCURE_URL=http://mercure:80/.well-known/mercure
SURREALDB_URL=ws://surrealdb:8000/rpc
SURREALDB_USER=root
SURREALDB_PASS=root

# --- Data fabric integration ---
MONGODB_URL=mongodb://mongodb:27017/agent_state
COUCHDB_URL=http://admin:password@couchdb:5984/obsidian
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- OpenHands git behavior ---
GIT_AUTHOR_NAME=openhands-bot
GIT_AUTHOR_EMAIL=openhands-bot@local
OPENHANDS_AUTO_COMMIT=true
OPENHANDS_BRANCH_PREFIX=openhands/

# --- Runtime locale/uid ---
PUID=1000
PGID=1000
TZ=America/New_York
