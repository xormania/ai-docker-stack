# stack identity
COMPOSE_PROJECT_NAME=ai-docker-stack
TZ=America/New_York

# versions / images
OLLAMA_IMAGE=ollama/ollama:latest
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
JUPYTER_IMAGE=quay.io/jupyter/pytorch-notebook:latest
OPEN_NOTEBOOKLM_IMAGE=pcoille/open-notebook:latest
DIFY_API_IMAGE=langgenius/dify-api:latest
DIFY_WEB_IMAGE=langgenius/dify-web:latest
FLOWISE_IMAGE=flowiseai/flowise:latest
OPENHANDS_IMAGE=ghcr.io/all-hands-ai/openhands:latest
N8N_IMAGE=docker.n8n.io/n8nio/n8n:latest
MERCURE_IMAGE=dunglas/mercure
GITEA_IMAGE=gitea/gitea:latest
SEARXNG_IMAGE=searxng/searxng:latest
ANYTHINGLLM_IMAGE=mintplexlabs/anythingllm:latest
RAGFLOW_IMAGE=infiniflow/ragflow:latest
UNSTRUCTURED_API_IMAGE=downloads.unstructured.io/unstructured-io/unstructured-api:latest
POSTGRES_IMAGE=postgres:16-alpine
MONGODB_IMAGE=mongo:latest
QDRANT_IMAGE=qdrant/qdrant:latest
SURREALDB_IMAGE=surrealdb/surrealdb:v2
REDIS_IMAGE=redis:7-alpine
MYSQL_IMAGE=mysql:8.0
MINIO_IMAGE=minio/minio
INFINITY_IMAGE=infiniflow/infinity:nightly
OBSIDIAN_REMOTE_IMAGE=sytone/obsidian-remote:latest
COUCHDB_IMAGE=couchdb:3.3

# ports
OPEN_WEBUI_PORT=3000
GITEA_HTTP_PORT=3001
GITEA_SSH_PORT=222
N8N_PORT=5678
FLOWISE_PORT=3003
OPENHANDS_PORT=3004
SEARXNG_PORT=8082
ANYTHINGLLM_PORT=3002
RAGFLOW_PORT=8083
UNSTRUCTURED_API_PORT=8021
MERCURE_PORT=8084
JUPYTER_PORT=8888
OPEN_NOTEBOOKLM_PORT=8502
OPEN_NOTEBOOKLM_API_PORT=5055
OBSIDIAN_REMOTE_PORT=8081
QDRANT_PORT=6333
SURREALDB_PORT=8000
MONGODB_PORT=27017
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
COUCHDB_PORT=5984
DIFY_WEB_PORT=80

# core credentials
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB_N8N=n8n
POSTGRES_DB_DIFY=dify
POSTGRES_DB_FLOWISE=flowise

MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE_RAGFLOW=ragflow
MYSQL_USER_RAGFLOW=ragflow
MYSQL_PASSWORD_RAGFLOW=change-me

COUCHDB_USER=admin
COUCHDB_PASSWORD=change-me

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me

SURREALDB_USER=root
SURREALDB_PASS=change-me

MERCURE_PUBLISHER_JWT_KEY=change-me-secret
MERCURE_SUBSCRIBER_JWT_KEY=change-me-secret
SERVER_NAME=:80

# service hosts
OLLAMA_HOST=ollama
OPEN_WEBUI_HOST=open-webui
POSTGRES_HOST=postgres
MONGODB_HOST=mongodb
QDRANT_HOST=qdrant
SURREALDB_HOST=surrealdb
REDIS_HOST=redis
MYSQL_HOST=mysql
MINIO_HOST=minio
INFINITY_HOST=infinity
COUCHDB_HOST=couchdb
GITEA_HOST=gitea
N8N_HOST=n8n
MERCURE_HOST=mercure
SEARXNG_HOST=searxng

# service internal ports
OLLAMA_PORT=11434
POSTGRES_PORT=5432
REDIS_PORT=6379
MYSQL_PORT=3306

# derived internal URLs
OLLAMA_BASE_URL=http://ollama:11434
QDRANT_URL=http://qdrant:6333
QDRANT_ENDPOINT=http://qdrant:6333
SURREALDB_URL=ws://surrealdb:8000/rpc
REDIS_URL=redis://redis:6379
MINIO_ENDPOINT=http://minio:9000
GITEA_BASE_URL=http://gitea:3000
N8N_BASE_URL=http://n8n:5678
MERCURE_URL=http://mercure/.well-known/mercure
SEARXNG_URL=http://searxng:8080
COUCHDB_URL=http://admin:change-me@couchdb:5984

# bootstrap / feature toggles
OLLAMA_BOOTSTRAP_MODEL=qwen3.5:current
JUPYTER_TOKEN=change-me
OBSIDIAN_PUID=1000
OBSIDIAN_PGID=1000
OPENHANDS_ENABLE_DOCKER_SOCKET=false