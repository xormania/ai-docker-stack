services:
  jupyter:
    image: ${JUPYTER_IMAGE}
    container_name: jupyter
    restart: always
    env_file:
      - ./env/dev.env
      - ./env/apps.env
    environment:
      JUPYTER_TOKEN: ${JUPYTER_TOKEN}
    ports:
      - "${JUPYTER_PORT}:8888"

  obsidian-remote:
    image: ${OBSIDIAN_REMOTE_IMAGE}
    container_name: obsidian-remote
    restart: always
    env_file:
      - ./env/dev.env
      - ./env/apps.env
    environment:
      PUID: ${OBSIDIAN_PUID}
      PGID: ${OBSIDIAN_PGID}
      TZ: ${TZ}
    ports:
      - "${OBSIDIAN_REMOTE_PORT}:8080"